# IMAP settings for newsletter ingestion.
# Copy this file to .env and fill in real values. .env is gitignored.
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=

# Newsletter sender emails to fetch (only used when EMAIL_SOURCE=imap).
# Comma-separated. The fetcher filters the mailbox to these senders so the
# whole inbox is never trawled. Required in IMAP mode — an empty value is a
# loud error, not a fetch-everything fallback.
IMAP_SENDERS=

# How many days back to fetch on the very first IMAP run, when no prior
# digest exists to resume from. Once a digest exists, subsequent runs resume
# from the last digest's date so a downtime gap is recovered fully.
# Defaults to 1 when unset.
IMAP_INITIAL_SINCE_DAYS=1

# DeepSeek API key for the LLM pipeline. Get one at
# https://platform.deepseek.com/api_keys. The real key lives in .env, which is
# gitignored. The OpenAI SDK talks to DeepSeek's OpenAI-compatible endpoint.
DEEPSEEK_API_KEY=

# OpenAI API key for embedding vectors. Get one at
# https://platform.openai.com/api-keys.
OPENAI_API_KEY=

# Where the startup digest pulls emails from.
#   samples (default) — read .eml files from backend/samples/
#   imap              — read a real mailbox via IMAP_* above; the startup
#                       trigger runs once a day (UTC) instead of per-file
EMAIL_SOURCE=samples
