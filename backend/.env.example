# IMAP settings for newsletter ingestion (used in T0003).
# Copy this file to .env and fill in real values. .env is gitignored.
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=

# Groq API key for the LLM pipeline (used from T0006). Get one at
# https://console.groq.com/keys. The real key lives in .env, which is gitignored.
GROQ_API_KEY=
